{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/psyb0t/wickworks/schema.json",
  "title": "Wickworks Compute API",
  "description": "Machine-readable contract for POST /. The wickworks HTTP surface is exactly two endpoints: POST / (compute) and GET /health. This schema validates the request body and describes the response envelope.",
  "type": "object",
  "$ref": "#/$defs/ComputeRequest",
  "$defs": {
    "Series": {
      "type": "array",
      "items": {
        "type": [
          "number",
          "null"
        ]
      },
      "description": "One value per bar (aligned 1:1 with input bars). Warmup positions are null."
    },
    "FlagSeries": {
      "type": "array",
      "items": {
        "type": "integer",
        "enum": [
          0,
          1
        ]
      },
      "description": "Per-bar 0/1 flag."
    },
    "DirectionSeries": {
      "type": "array",
      "items": {
        "type": "integer",
        "enum": [
          -1,
          1
        ]
      },
      "description": "Per-bar direction marker: 1 = bullish/long, -1 = bearish/short."
    },
    "Bar": {
      "type": "object",
      "properties": {
        "time": {
          "type": "integer",
          "description": "UTC unix seconds."
        },
        "open": {
          "type": "number"
        },
        "high": {
          "type": "number"
        },
        "low": {
          "type": "number"
        },
        "close": {
          "type": "number"
        },
        "tickVolume": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Canonical volume field. All volume-based indicators (VWAP, OBV, VWMA, MFI, CMF, AD, ADOSC, KVO) read this."
        },
        "realVolume": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Accepted for forward-compat. Indicator math currently reads tickVolume, not this."
        }
      },
      "required": [
        "time",
        "open",
        "high",
        "low",
        "close"
      ]
    },
    "ComputeRequest": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "default": "",
          "description": "Echoed in response."
        },
        "timeframe": {
          "type": "string",
          "default": "",
          "description": "Echoed in response."
        },
        "recentBars": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Reserved for future signal-tagging windows. Currently unused \u2014 wickworks emits primitives only and no output type is recency-tagged."
        },
        "bars": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Bar"
          },
          "description": "OHLC(V) bars in chronological order. Length <= MAX_BARS (default 5000)."
        },
        "indicators": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              {
                "const": true,
                "description": "Run the indicator named by the output key with default params."
              },
              {
                "$ref": "#/$defs/IndicatorSpec"
              }
            ]
          },
          "description": "Map of outputKey -> spec."
        }
      },
      "required": [
        "bars",
        "indicators"
      ]
    },
    "IndicatorSpec": {
      "description": "Any indicator request spec. The `type` field discriminates; when omitted at runtime, the output-key name is used as the type.",
      "oneOf": [
        {
          "$ref": "#/$defs/LengthBasedRequest"
        },
        {
          "$ref": "#/$defs/ObvAdRequest"
        },
        {
          "$ref": "#/$defs/AdoscRequest"
        },
        {
          "$ref": "#/$defs/UoRequest"
        },
        {
          "$ref": "#/$defs/VwapRequest"
        },
        {
          "$ref": "#/$defs/MacdRequest"
        },
        {
          "$ref": "#/$defs/StochRequest"
        },
        {
          "$ref": "#/$defs/StochRsiRequest"
        },
        {
          "$ref": "#/$defs/AdxRequest"
        },
        {
          "$ref": "#/$defs/AroonRequest"
        },
        {
          "$ref": "#/$defs/VortexRequest"
        },
        {
          "$ref": "#/$defs/TsiRequest"
        },
        {
          "$ref": "#/$defs/TrixRequest"
        },
        {
          "$ref": "#/$defs/KvoRequest"
        },
        {
          "$ref": "#/$defs/FisherRequest"
        },
        {
          "$ref": "#/$defs/BbandsRequest"
        },
        {
          "$ref": "#/$defs/KcRequest"
        },
        {
          "$ref": "#/$defs/DonchianRequest"
        },
        {
          "$ref": "#/$defs/SqueezeRequest"
        },
        {
          "$ref": "#/$defs/SupertrendRequest"
        },
        {
          "$ref": "#/$defs/PsarRequest"
        },
        {
          "$ref": "#/$defs/IchimokuRequest"
        },
        {
          "$ref": "#/$defs/ChandelierExitRequest"
        },
        {
          "$ref": "#/$defs/OrderBlocksRequest"
        },
        {
          "$ref": "#/$defs/FvgRequest"
        },
        {
          "$ref": "#/$defs/BosChochRequest"
        },
        {
          "$ref": "#/$defs/SwingLevelsRequest"
        },
        {
          "$ref": "#/$defs/SrLevelsRequest"
        },
        {
          "$ref": "#/$defs/RecentRangeRequest"
        },
        {
          "$ref": "#/$defs/LiquidityRequest"
        },
        {
          "$ref": "#/$defs/PreviousHighLowRequest"
        },
        {
          "$ref": "#/$defs/SessionsRequest"
        },
        {
          "$ref": "#/$defs/RetracementsRequest"
        },
        {
          "$ref": "#/$defs/PriceRequest"
        },
        {
          "$ref": "#/$defs/LevelsRequest"
        },
        {
          "$ref": "#/$defs/MomentumRequest"
        },
        {
          "$ref": "#/$defs/VolumeRequest"
        },
        {
          "$ref": "#/$defs/PositionRequest"
        },
        {
          "$ref": "#/$defs/SlopeRequest"
        },
        {
          "$ref": "#/$defs/TypelessSpec"
        }
      ]
    },
    "TypelessSpec": {
      "type": "object",
      "description": "Spec with no `type` field. The output-key name is used as the indicator type at runtime. Any indicator-specific params (length, fast, slow, \u2026) may appear here.",
      "not": {
        "required": [
          "type"
        ]
      }
    },
    "LengthBasedRequest": {
      "type": "object",
      "description": "27 indicators share this spec. Default `length` varies per type (see README table).",
      "properties": {
        "type": {
          "enum": [
            "rsi",
            "atr",
            "natr",
            "cci",
            "willr",
            "roc",
            "mom",
            "mfi",
            "cmf",
            "vwma",
            "ema",
            "sma",
            "hma",
            "wma",
            "dema",
            "tema",
            "t3",
            "kama",
            "alma",
            "linreg",
            "jma",
            "zlma",
            "rma",
            "fwma",
            "swma",
            "sinwma",
            "trima"
          ]
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "description": "Lookback window."
        },
        "c": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.015,
          "description": "Scaling constant \u2014 cci only."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "ObvAdRequest": {
      "type": "object",
      "description": "Cumulative volume lines (no params).",
      "properties": {
        "type": {
          "enum": [
            "obv",
            "ad"
          ]
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "AdoscRequest": {
      "type": "object",
      "description": "Chaikin Accumulation/Distribution Oscillator.",
      "properties": {
        "type": {
          "const": "adosc"
        },
        "fast": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "slow": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "UoRequest": {
      "type": "object",
      "description": "Ultimate Oscillator.",
      "properties": {
        "type": {
          "const": "uo"
        },
        "fast": {
          "type": "integer",
          "minimum": 1,
          "default": 7
        },
        "medium": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        },
        "slow": {
          "type": "integer",
          "minimum": 1,
          "default": 28
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "VwapRequest": {
      "type": "object",
      "description": "Session-anchored VWAP.",
      "properties": {
        "type": {
          "const": "vwap"
        },
        "anchor": {
          "type": "string",
          "enum": [
            "D",
            "W",
            "M"
          ],
          "default": "D"
        },
        "sessionOffset": {
          "type": [
            "string",
            "number"
          ],
          "default": "0s",
          "description": "Go-style duration (\"-5h\", \"1h30m\") or seconds. Examples: -5h NY, -2h EET, 7h Tokyo."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "MacdRequest": {
      "type": "object",
      "description": "MACD.",
      "properties": {
        "type": {
          "const": "macd"
        },
        "fast": {
          "type": "integer",
          "minimum": 1,
          "default": 12
        },
        "slow": {
          "type": "integer",
          "minimum": 1,
          "default": 26
        },
        "signal": {
          "type": "integer",
          "minimum": 1,
          "default": 9
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "StochRequest": {
      "type": "object",
      "description": "Stochastic oscillator.",
      "properties": {
        "type": {
          "const": "stoch"
        },
        "k": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        },
        "d": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "smoothK": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "StochRsiRequest": {
      "type": "object",
      "description": "Stochastic RSI.",
      "properties": {
        "type": {
          "const": "stochrsi"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        },
        "rsiLength": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        },
        "k": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "d": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "AdxRequest": {
      "type": "object",
      "description": "Average Directional Index + DMI.",
      "properties": {
        "type": {
          "const": "adx"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "AroonRequest": {
      "type": "object",
      "description": "Aroon up/down + oscillator.",
      "properties": {
        "type": {
          "const": "aroon"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "VortexRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "vortex"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "TsiRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "tsi"
        },
        "fast": {
          "type": "integer",
          "minimum": 1,
          "default": 13
        },
        "slow": {
          "type": "integer",
          "minimum": 1,
          "default": 25
        },
        "signal": {
          "type": "integer",
          "minimum": 1,
          "default": 13
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "TrixRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "trix"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "signal": {
          "type": "integer",
          "minimum": 1,
          "default": 9
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "KvoRequest": {
      "type": "object",
      "description": "Klinger Volume Oscillator \u2014 requires volume.",
      "properties": {
        "type": {
          "const": "kvo"
        },
        "fast": {
          "type": "integer",
          "minimum": 1,
          "default": 34
        },
        "slow": {
          "type": "integer",
          "minimum": 1,
          "default": 55
        },
        "signal": {
          "type": "integer",
          "minimum": 1,
          "default": 13
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "FisherRequest": {
      "type": "object",
      "description": "Ehlers Fisher Transform.",
      "properties": {
        "type": {
          "const": "fisher"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 9
        },
        "signal": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "BbandsRequest": {
      "type": "object",
      "description": "Bollinger Bands.",
      "properties": {
        "type": {
          "const": "bbands"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        },
        "std": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 2.0
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "KcRequest": {
      "type": "object",
      "description": "Keltner Channels.",
      "properties": {
        "type": {
          "const": "kc"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        },
        "scalar": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 2.0
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "DonchianRequest": {
      "type": "object",
      "description": "Donchian Channels.",
      "properties": {
        "type": {
          "const": "donchian"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SqueezeRequest": {
      "type": "object",
      "description": "TTM Squeeze (Bollinger inside Keltner).",
      "properties": {
        "type": {
          "const": "squeeze"
        },
        "bbLength": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        },
        "bbStd": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 2.0
        },
        "kcLength": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        },
        "kcScalar": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.5
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SupertrendRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "supertrend"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 7
        },
        "multiplier": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 3.0
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "PsarRequest": {
      "type": "object",
      "description": "Parabolic SAR.",
      "properties": {
        "type": {
          "const": "psar"
        },
        "af": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.02
        },
        "max": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.2
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "IchimokuRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ichimoku"
        },
        "tenkan": {
          "type": "integer",
          "minimum": 1,
          "default": 9
        },
        "kijun": {
          "type": "integer",
          "minimum": 1,
          "default": 26
        },
        "senkou": {
          "type": "integer",
          "minimum": 1,
          "default": 52
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "ChandelierExitRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "chandelierExit"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "default": 22
        },
        "atrLength": {
          "type": "integer",
          "minimum": 1,
          "default": 22
        },
        "multiplier": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 2.0
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "OrderBlocksRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "orderBlocks"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "FvgRequest": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "fvg",
            "fvgs"
          ]
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "BosChochRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "bosChoch"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SwingLevelsRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "swingLevels"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SrLevelsRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "srLevels"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "RecentRangeRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "recentRange"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "LiquidityRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "liquidity"
        },
        "swingLength": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "rangePercent": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.01
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "PreviousHighLowRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "previousHighLow"
        },
        "timeFrame": {
          "type": "string",
          "default": "1D",
          "description": "Pandas resample freq (\"1D\", \"1W\", \"4h\")."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SessionsRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "sessions"
        },
        "session": {
          "type": "string",
          "default": "London",
          "description": "Session name as accepted by smartmoneyconcepts (\"London\", \"New York\", \"Tokyo\", \"Sydney\", \u2026)."
        },
        "startTime": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Override session start (HH:MM, exchange-local)."
        },
        "endTime": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Override session end (HH:MM, exchange-local)."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "RetracementsRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "retracements"
        },
        "swingLength": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "PriceRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "price"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "LevelsRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "levels"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "MomentumRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "momentum"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "VolumeRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "volume"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "PositionRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "position"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "SlopeRequest": {
      "type": "object",
      "properties": {
        "type": {
          "const": "slope"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "OrderBlock": {
      "type": "object",
