    "InsufficientBarsError": {
      "type": "object",
      "description": "HTTP 400 body when one or more requested indicators need more bars than were submitted. Every under-fed indicator is listed in `deficits` so the entire call can be fixed in one round trip.",
      "properties": {
        "detail": {
          "type": "object",
          "properties": {
            "error": {
              "const": "insufficient_bars"
            },
            "message": {
              "type": "string"
            },
            "available": {
              "type": "integer",
              "minimum": 0
            },
            "deficits": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "outputKey": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "required": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "available": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "outputKey",
                  "type",
                  "required",
                  "available"
                ]
              }
            }
          },
          "required": [
            "error",
            "message",
            "available",
            "deficits"
          ]
        }
      },
      "required": [
        "detail"
      ]
    }
